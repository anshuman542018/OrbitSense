# --- Python ---
.venv/
__pycache__/
*.pyc
*.egg-info/
build/
dist/

# --- Data (regenerated by the pipeline; lives on the `data` branch) ---
data/

# --- Secrets & credentials (never commit) ---
.env
.env.*
*.env
secrets*
*secret*
*.key
*.pem
*.p12
*.pfx
*credential*
*token*
service-account*.json
gcp-*.json
.netrc

# --- Private / strategy documents (keep local, don't publish) ---
*.pdf
*blue_print*
*blueprint*
*_private*
*_confidential*

# --- Docs: keep everything local except the public ones ---
*.md
!README.md
!DETECTION_METHODS.md
!ARCHITECTURE.md
!ETHICS_AND_SCOPE.md

# --- Web app ---
site/node_modules/
site/.next/
site/.vercel/
.vercel/

# --- Local artifacts ---
scripts/*.png
*.log
.DS_Store
